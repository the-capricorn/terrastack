# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data points which are potentially sensitive and subject
# to change depending on the environment.
*.tfvars
*.tfvars.json

# terraform.tfvars contains only non-sensitive configuration and is intentionally tracked
!terraform.tfvars

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Provider dependency lock file — not committed for reusable module libraries.
# Consumers pin their own provider versions in their root module's lock file.
.terraform.lock.hcl

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Terraform plan output and visualization artifacts
tfplan
tfplan.json
graph.svg
graph.dot

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Terraform plan identity credentials (generated by tools/create-plan-identity.sh)
tools/terraform-plan.env

# .claude/ is intentionally tracked in the private repo.
# It is excluded from the public release by .github/workflows/publish-public.yml.
